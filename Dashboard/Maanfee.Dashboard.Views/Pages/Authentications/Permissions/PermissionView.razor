@page "/Permissions/PermissionView"
@inherits _BaseView

<MaanfeeDashboardPage PageTitle="@DashboardResource.StringPermission">
    @if (!IsLoaded)
    {
        <SVGOverlay Random="true" />
    }
    else
    {
        <MudCard>
            <MudCardHeader>
                <MudText Typo="Typo.button" Color="Color.Primary">
                    @DashboardResource.StringPermission
                </MudText>
            </MudCardHeader>
            <MudDivider DividerType="DividerType.FullWidth" />
            <MudCardContent>
                <MudGrid>
                    <MudItem md="6" xs="6">
                        <EditForm OnValidSubmit="OnSubmit" Model="Model">
                            <DataAnnotationsValidator />
                            <MudCard>
                                <MudCardContent>
                                    <MudGrid>
                                        <MudItem md="12">
                                            <MudTextField Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.AccountTree"
                                                          @bind-Value="Model.Title"
                                                          For="@(() => Model.Title)"
                                                          Label="@DashboardResource.StringTitle" />
                                        </MudItem>
                                        <MudItem md="12">
                                            <MudTextField Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.AccountTree"
                                                          @bind-Value="Model.DisplayTitle"
                                                          For="@(() => Model.DisplayTitle)"
                                                          Label="@DashboardResource.StringDisplayTitle" />
                                        </MudItem>
                                        <MudItem md="12">
                                            <MudAutocomplete T="DropDownPermissionViewModel" Label="@DashboardResource.StringParent"
                                                             ResetValueOnEmptyText="true" Clearable="true" MaxItems="null"
                                                             @bind-Value="Model.Parent" Variant="Variant.Outlined"
                                                             SearchFunc="GetParentsAsync" ToStringFunc="@(e=> e==null?null : $"{e.Title}")" />
                                        </MudItem>
                                        <MudItem md="12">
                                            <MudTextField Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.AccountTree"
                                                          @bind-Value="Model.FullName" Disabled
                                                          For="@(() => Model.FullName)"
                                                          Label="@DashboardResource.StringFullName" />
                                        </MudItem>
                                    </MudGrid>
                                </MudCardContent>
                            </MudCard>
                            <MudPaper Class="pa-3 my-2 ActionColor" Elevation="3" Outlined="true" Square="true">
                                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Start">
                                    <MudButton Disabled="@IsProcessing" ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Tertiary">
                                        @if (IsProcessing)
                                        {
                                            <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                                            <MudText Class="ms-2">@DashboardResource.StringProcessing</MudText>
                                        }
                                        else
                                        {
                                            <MudIcon Icon="@Icons.Material.Filled.Save" Color="Color.Surface" />
                                            <MudText>@DashboardResource.StringSave</MudText>
                                        }
                                    </MudButton>
                                    <MudButton OnClick="@((e) => OpenDeleteDialog())" Variant="Variant.Filled" Color="Color.Error"
                                               Disabled=@(string.IsNullOrEmpty(Model.Id) ? true : false)>
                                        <MudIcon Icon="@Icons.Material.Filled.DeleteForever" Color="Color.Surface" />
                                        <MudText>@DashboardResource.StringDelete</MudText>
                                    </MudButton>
                                    <MudButton OnClick="@ResetAsync" Variant="Variant.Filled" Color="Color.Secondary"
                                               StartIcon="@Icons.Material.Filled.Refresh" IconColor="Color.Surface">
                                        @DashboardResource.StringReload
                                    </MudButton>
                                </MudStack>
                            </MudPaper>

                            @{
                                if (SelectedValue != null)
                                {
                                    Model.Id = SelectedValue?.Id ?? null;
                                    Model.Title = SelectedValue?.Title;
                                    Model.DisplayTitle = SelectedValue?.DisplayTitle;
                                    Model.FullName = SelectedValue?.FullName;
                                    Model.Parent = Parents.FirstOrDefault(x => x.Id == SelectedValue?.IdParent) ?? null;

                                    SelectedValue = null;
                                }
                            }
                        </EditForm>
                    </MudItem>
                    <MudItem md="6" xs="6">
                        <MudCard>
                            <MudCardHeader>
                                <CardHeaderContent>
                                    <MudText Color="Color.Error">@DashboardResource.StringOrganizationalChart</MudText>
                                </CardHeaderContent>
                                @*    <CardHeaderActions>
                                    <MudTextField T="string" Label="@DashboardResource.StringSearch" Immediate="true"
                                                  AdornmentIcon="@Icons.Material.Filled.Search" Clearable="true"
                                                  Variant="Variant.Outlined" Adornment="Adornment.Start"
                                                  TextChanged="OnTextChanged" />
                                </CardHeaderActions> *@
                            </MudCardHeader>
                            <MudDivider DividerType="DividerType.FullWidth" />
                            <MudCardContent>
                                <MudTreeView ServerData="@LoadServerData" Items="@TreeItems" T="Permission"
                                             Hover Color="Color.Tertiary" @bind-SelectedValue="SelectedValue">
                                    <ItemTemplate>
                                        <MudTreeViewItem T="Permission"
                                                         IconColor="Color.Primary"
                                                         ExpandButtonIconColor="Color.Primary"
                                                         Value="@context.Value"
                                                         Text="@context.Text"
                                                         Items="@context.Children"
                                                         @bind-Expanded="@context.Expanded"
                                                         CanExpand="@context.Expandable"
                                                         Icon="@context.Icon"
                                                         LoadingIconColor="Color.Primary" />
                                    </ItemTemplate>
                                </MudTreeView>
                            </MudCardContent>
                        </MudCard>
                    </MudItem>
                </MudGrid>
            </MudCardContent>
        </MudCard>
    }
</MaanfeeDashboardPage>
