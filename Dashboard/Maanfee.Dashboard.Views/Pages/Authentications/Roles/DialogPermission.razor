@inherits _BaseView

<MaanfeeDashboardDialog @ref="MDialog" IsDialogLoaded="@IsLoaded" Title="@($"{DashboardResource.StringManagePermission} - {RoleName}")" DialogContentType="@(this.GetType())">
    <MaanfeeDashboardDialogHeaderAction>
        <MudTooltip Text="@DashboardResource.StringCreate" Color="Color.Tertiary" Arrow>
            <MudIconButton Disabled="@IsProcessing" OnClick="SaveAsync" Icon="@Icons.Material.Filled.Save" Color="Color.Tertiary">
                @if (IsProcessing)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="ms-n1" />
                    <MudText Class="ms-2">@DashboardResource.StringProcessing</MudText>
                }
                else
                {
                    <MudIcon Icon="@Icons.Material.Filled.Save" Color="Color.Surface" Class="mx-1" />
                    <MudText>@DashboardResource.StringSave</MudText>
                }
            </MudIconButton>
        </MudTooltip>
    </MaanfeeDashboardDialogHeaderAction>
    <MaanfeeDashboardDialogContent>
        <MudTreeView ServerData="@LoadServerData" Items="@TreeItems" T="Permission" Hover
                     SelectionMode="SelectionMode.MultiSelection" CheckBoxColor="Color.Primary"
                     Color="Color.Tertiary" @bind-SelectedValues="SelectedValues">
            <ItemTemplate>
                <MudTreeViewItem T="Permission"
                                 IconColor="Color.Primary"
                                 ExpandButtonIconColor="Color.Primary"
                                 Value="@context.Value"
                                 Text="@context.Text"
                                 Items="@context.Children"
                                 @bind-Expanded="@context.Expanded"
                                 CanExpand="@context.Expandable"
                                 Icon="@context.Icon"
                                 LoadingIconColor="Color.Primary" />
            </ItemTemplate>
        </MudTreeView>
    </MaanfeeDashboardDialogContent>
</MaanfeeDashboardDialog>

@code {

    private MaanfeeDashboardDialog MDialog = new();

    // *****************************************************

}
