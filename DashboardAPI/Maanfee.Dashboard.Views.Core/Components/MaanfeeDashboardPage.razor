@namespace Maanfee.Dashboard.Views.Core
@inherits _BaseView

<PageTitle>@PageTitle</PageTitle>

<link rel="stylesheet" href="@Assets["_content/Maanfee.Dashboard.Views.Core/styles.css"]" />

<CascadingValue Value="this" IsFixed>
    @ChildContent
</CascadingValue>

@code {

    [Parameter]
    public string PageTitle { get; set; } = "Title";

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

}
